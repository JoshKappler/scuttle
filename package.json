{
  "name": "scuttle",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Pirate voxel naval plunder-tycoon.",
  "author": "boffytv",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "electron .",
    "dist": "npm run build && electron-builder -c.directories.output=%USERPROFILE%\\scuttle-release"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "simplex-noise": "^4.0.3",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.scuttle.game",
    "productName": "SCUTTLE",
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable"
    }
  }
}
