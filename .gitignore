node_modules/
dist/
*.local
.DS_Store

# Desktop build output (electron-builder). The packaged EXE goes to
# %USERPROFILE%\scuttle-release\ (out of the repo); this catches any in-repo run.
release/

# Local Claude Code tooling (shared-worktree guard, linked worktrees, settings).
# Kept on disk for the dev workflow but out of the showcase repo.
.claude/

# Local playtest console logs (preserved on disk, kept out of the showcase repo)
docs/playtest-logs/

# Icon-build scratch + derived previews (regenerated by build/make-icon.cjs).
# The committed inputs are icon.svg / skull*.png(.jpg) / make-icon.cjs and the output icon.ico.
build/cand/
build/.icontmp/
build/icon.png
build/icon-sizes.png

# Playwright MCP scratch output (screenshots/snapshots/console logs from in-browser verification)
.playwright-mcp/

# Bugrimov pirate RAW drop (~2GB of FBX + uncompressed TGA + UE/Unity projects).
# Only the optimized web export (bugrimov/web/) and README are committed.
public/assets/characters/bugrimov/Models_UE4_UE5/
public/assets/characters/bugrimov/Models_Unity/
public/assets/characters/bugrimov/UE4_Project/
public/assets/characters/bugrimov/Unity_Project/

# Quaternius Universal RAW drop — keep only web/ + the README
public/assets/characters/universal/*
!public/assets/characters/universal/web/
!public/assets/characters/universal/README_DROP_HERE.md

# Quaternius Modular Character Outfits (Fantasy) RAW drop — keep only web/ + README
public/assets/characters/outfits/*
!public/assets/characters/outfits/web/
!public/assets/characters/outfits/README.md

# Quaternius/Kenney Pirate Kit RAW drop — keep only web/ + README
public/assets/props/piratekit/*
!public/assets/props/piratekit/web/
!public/assets/props/piratekit/README.md
